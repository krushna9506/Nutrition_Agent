# ============================================================
# IBM Watsonx.ai - Nutrition Agent Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control

# ----------------------------------------------------------
# IBM Cloud API Key
# Get yours at: https://cloud.ibm.com/iam/apikeys
# ----------------------------------------------------------
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# ----------------------------------------------------------
# IBM Watsonx.ai Project ID
# Found in your Watsonx.ai project settings
# ----------------------------------------------------------
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# ----------------------------------------------------------
# IBM Watsonx.ai URL (region-specific)
# Options:
#   https://au-syd.ml.cloud.ibm.com    (Sydney) ← DEFAULT
#   https://eu-de.ml.cloud.ibm.com     (Frankfurt)
#   https://eu-gb.ml.cloud.ibm.com     (London)
#   https://jp-tok.ml.cloud.ibm.com    (Tokyo)
# ----------------------------------------------------------
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ----------------------------------------------------------
# Flask Application Settings
# ----------------------------------------------------------
FLASK_SECRET_KEY=nutrition_agent_super_secret_key_change_in_production
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# ----------------------------------------------------------
# Application Settings
# ----------------------------------------------------------
APP_NAME=NutriAI Agent
MAX_TOKENS=2048
TEMPERATURE=0.7
